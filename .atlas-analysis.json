  "keyFeatures": [
    "Unified CLI for Jira, Confluence, Bitbucket, and Bamboo Data Center products",
    "Local auth profile management with named profiles and easy switching",
    "Declarative release gate system via cops.project.json",
    "Release evidence generation, validation, diff, and trend analysis",
    "Dynamic repo discovery from Jira dev-status links",
    "Stable JSON output (schemaVersion v1) for automation and scripting",
    "Table, JSON, and Markdown output formats for all data commands",
    "Cross-product release readiness checks in a single command"
  ],
